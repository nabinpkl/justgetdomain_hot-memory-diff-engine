# ─── Domain list provider ─────────────────────────────────────────────
# Default OFF: the server boots from the on-disk snapshot.bin and serves
# it as-is, no scheduler, no nightly download. Flip to true / 1 / yes / on
# to re-enable the nightly batch pipeline.
DOWNLOAD_DOMAINS=false

# Provider URL with API key. REQUIRED only when DOWNLOAD_DOMAINS=true;
# ignored otherwise. Never commit the real value — copy this file to .env
# and fill it in there. Swap providers by changing the URL.
# DOMAINS_DOWNLOAD_URL=https://example.com/api/v1/<API_KEY>/get/full/list/zip

# ─── Schedule (all optional; defaults shown) ──────────────────────────
# Hour of day (0-23) in BATCH_TIMEZONE when the nightly batch should run.
BATCH_START_HOUR_CET=0

# How many hours the batch-window stays open. If the server is down when
# the window opens but up before it closes, the batch still fires.
BATCH_WINDOW_HOURS=1

# IANA timezone name. Use Europe/Berlin for CET (handles DST automatically).
BATCH_TIMEZONE=Europe/Berlin

# If the current snapshot is older than this, the scheduler runs a batch
# immediately on startup instead of waiting for the next window. This is
# the mechanism that catches up after downtime.
STALE_AFTER_HOURS=25

# ─── Paths (optional) ─────────────────────────────────────────────────
DATA_DIR=/app/data
SNAPSHOT_PATH=/app/data/snapshot.bin
DOMAINS_TXT_PATH=/app/data/domains.txt
DOMAINS_ZIP_PATH=/app/data/domains.zip

# ─── Download hygiene (optional) ──────────────────────────────────────
# HTTP request timeout in seconds. The file is ~1–3 GB compressed.
DOWNLOAD_TIMEOUT_SECS=1800

# Reject downloads smaller than this many bytes — typically an error page
# or rate-limit response masquerading as a 200 OK.
MIN_DOWNLOAD_BYTES=100000000

# ─── Server ───────────────────────────────────────────────────────────
PORT=8001
CORS_ORIGIN=*
RUST_LOG=info

# ─── Cloudflare Tunnel ────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=
